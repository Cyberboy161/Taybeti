<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".TaybetiApp"
        android:allowBackup="false"
        android:fullBackupOnly="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Taybeti">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Taybeti">
        </activity>

        <!-- Taybeti (default) -->
        <activity-alias
            android:name=".MainActivityTaybeti"
            android:targetActivity=".MainActivity"
            android:enabled="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Taybeti Notesharing"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Disguise aliases — user can switch between these to hide the app -->
        <activity-alias
            android:name=".MainActivityCalc"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:icon="@drawable/ic_disguise_calc"
            android:label="Calculator"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityNotes"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:icon="@drawable/ic_disguise_notes"
            android:label="Notes"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityClock"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:icon="@drawable/ic_disguise_clock"
            android:label="Clock"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivitySettings"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:icon="@drawable/ic_disguise_settings"
            android:label="Settings"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
